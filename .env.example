# =============================================================================
# AI Guard Demo — variables de entorno
# =============================================================================
# Copia este archivo a `.env` (cp .env.example .env) y completa los valores.
# Todas son OPCIONALES — sin ninguna, la demo corre en modo MOCK + canned.
# =============================================================================

# --- Trend Micro AI Guard ----------------------------------------------------
# Tu API key de Trend Vision One. Necesita scope de AI Guard habilitado.
TREND_API_KEY=

# IMPORTANTE: el endpoint es REGIONAL. Tienes que usar el correspondiente a la
# región de tu tenant de Vision One. El dominio del portal te indica la región:
#
#   portal.xdr.trendmicro.com         (US)        → api.xdr.trendmicro.com
#   portal.eu.xdr.trendmicro.com      (Europa)    → api.eu.xdr.trendmicro.com
#   portal.au.xdr.trendmicro.com      (Australia) → api.au.xdr.trendmicro.com
#   portal.jp.xdr.trendmicro.com      (Japón)     → api.jp.xdr.trendmicro.com
#   portal.sg.xdr.trendmicro.com      (Singapur)  → api.sg.xdr.trendmicro.com
#   portal.in.xdr.trendmicro.com      (India)     → api.in.xdr.trendmicro.com
#   portal.mea.xdr.trendmicro.com     (MEA)       → api.mea.xdr.trendmicro.com
#
# Path completo del endpoint de AI Guard:
#   https://<api-region>/beta/aiSecurity/guard
#
# Ejemplo para US (ajusta a tu región):
TREND_GUARD_ENDPOINT=https://api.xdr.trendmicro.com/beta/aiSecurity/guard

# --- LLM (opcional, pero recomendado para conversación natural) -------------
# Con OPENAI_API_KEY, las respuestas "normales" salen de gpt-4o-mini.
# Sin ella → respuestas canned (limitadas pero funcionales).
# Los ataques SIMULADOS son siempre locales — no consumen tokens.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Servidor ----------------------------------------------------------------
HOST=0.0.0.0
PORT=8000
